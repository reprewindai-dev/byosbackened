# BYOS AI Backend - Environment Variables Example
# Copy this to .env and fill in your values

# App
APP_NAME=BYOS AI Backend
APP_VERSION=0.1.0
DEBUG=false
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/byos_ai

# Redis
REDIS_URL=redis://redis:6379/0

# S3/MinIO
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=byos-ai
S3_REGION=us-east-1
S3_USE_SSL=false

# Security
SECRET_KEY=change-me-in-production-use-env-var-generate-with-openssl-rand-hex-32
ENCRYPTION_KEY=  # Optional, defaults to SECRET_KEY if not set
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI Providers

# Hugging Face (Primary - free-ish, most tokens)
HUGGINGFACE_API_KEY=your_hf_token_here
HUGGINGFACE_MODEL_CHAT=mistralai/Mistral-7B-Instruct-v0.1
HUGGINGFACE_MODEL_EMBED=sentence-transformers/all-MiniLM-L6-v2

# SERP API (Search)
SERPAPI_KEY=your_serpapi_key_here

# OpenAI (Optional - only when valuable, must be documented)
OPENAI_API_KEY=
OPENAI_MODEL_CHAT=gpt-4o-mini
OPENAI_MODEL_WHISPER=whisper-1

# Local AI (Self-hosted - optional)
LOCAL_WHISPER_URL=
LOCAL_LLM_URL=

# Worker
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# CORS
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=true

# Observability (Optional)
SENTRY_DSN=  # For error tracking
LOG_FORMAT=json  # "json" or "text"
METRICS_ENABLED=true
PROMETHEUS_PORT=9090

# Stripe Payment Processing
STRIPE_SECRET_KEY=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
