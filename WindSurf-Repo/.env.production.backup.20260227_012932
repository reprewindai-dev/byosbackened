# Production Environment Configuration
# ==================================

# Build Information
BUILD_DATE=$(date -u +'%Y-%m-%dT%H:%M:%SZ')
VCS_REF=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
VERSION=1.0.0

# Environment
ENVIRONMENT=production

# Security Keys (Generate new ones for production)
SECRET_KEY=your-super-secure-64-character-random-secret-key-here-change-this
AI_CITIZENSHIP_SECRET=your-ai-citizenship-secret-key-here-change-this

# Database Configuration
POSTGRES_PASSWORD=your-secure-postgres-password-here
DATABASE_URL=postgresql://sovereign_user:your-secure-postgres-password-here@postgres:5432/sovereign_production

# Redis Configuration
REDIS_PASSWORD=your-secure-redis-password-here
REDIS_URL=redis://:your-secure-redis-password-here@redis:6379/0
CELERY_BROKER_URL=redis://:your-secure-redis-password-here@redis:6379/0
CELERY_RESULT_BACKEND=redis://:your-secure-redis-password-here@redis:6379/0

# Application URLs
FRONTEND_URL=https://your-domain.com
API_URL=https://api.your-domain.com

# AI Provider Keys
HUGGINGFACE_API_KEY=hf_your-huggingface-token-here
OPENAI_API_KEY=sk-your-openai-key-here

# Billing Configuration
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key-here
STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key-here

# Monitoring Configuration
GRAFANA_PASSWORD=your-secure-grafana-password-here

# SSL Configuration (if using self-signed certs for development)
SSL_CERT_PATH=/app/infra/docker/ssl/cert.pem
SSL_KEY_PATH=/app/infra/docker/ssl/key.pem

# Performance Settings
WORKERS=4
MAX_CONNECTIONS=100
KEEPALIVE_TIMEOUT=65

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Security Settings
ENABLE_MFA=true
PASSWORD_MIN_LENGTH=12
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MINUTES=30

# Rate Limiting
RATE_LIMIT_PER_MINUTE=1000
RATE_LIMIT_BURST=2000

# Cache Settings
CACHE_TTL=300
CACHE_MAX_SIZE=1000

# Backup Settings
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# Health Check Settings
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_RETRIES=3
