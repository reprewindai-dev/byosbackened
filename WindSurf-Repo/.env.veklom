# ─────────────────────────────────────────────────────────────────────────────
# GoonVault Production Environment — veklom.dev
# Copy this file to .env on the server, then fill in the CHANGE_ME values.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME="GoonVault"
DEBUG=false
ENVIRONMENT=production
API_PREFIX=/api/v1
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Secrets — GENERATE THESE (instructions below) ─────────────────────────────
# Run this to generate each one:  openssl rand -hex 32
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
AI_CITIZENSHIP_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# ── URLs ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://veklom.dev
API_URL=https://veklom.dev

# ── Database (auto-wired by docker-compose) ────────────────────────────────────
DATABASE_URL=postgresql://goonvault_user:CHANGE_ME_strong_db_password@postgres:5432/goonvault_prod

# ── Redis (auto-wired by docker-compose) ──────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME_strong_redis_password@redis:6379/0
CELERY_BROKER_URL=redis://:CHANGE_ME_strong_redis_password@redis:6379/0
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_strong_redis_password@redis:6379/0

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["https://veklom.dev","https://www.veklom.dev"]
CORS_ALLOW_CREDENTIALS=true

# ── Stripe (your live keys — already in your .env) ────────────────────────────
STRIPE_SECRET_KEY=PASTE_YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_PUBLISHABLE_KEY=PASTE_YOUR_STRIPE_PUBLISHABLE_KEY_HERE
# Get this from: Stripe Dashboard → Webhooks → veklom.dev/api/v1/stripe/webhook
STRIPE_WEBHOOK_SECRET=CHANGE_ME_get_from_stripe_dashboard

# ── AI Providers (optional — platform works without these) ────────────────────
HUGGINGFACE_API_KEY=
OPENAI_API_KEY=
LLM_MODEL_DEFAULT=qwen2.5:1.5b

# ── Build metadata (leave as-is) ──────────────────────────────────────────────
BUILD_DATE=2026-01-01
VCS_REF=main
VERSION=1.0.0
GRAFANA_PASSWORD=CHANGE_ME_grafana_admin_password
