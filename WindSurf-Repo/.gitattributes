# Ensure shell scripts use LF line endings
*.sh text eol=lf

# Python files
*.py text eol=lf

# Configuration files
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.conf text eol=lf

# Environment files (but don't commit .env itself)
.env.example text eol=lf
.env.* text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Docker files
Dockerfile* text eol=lf
docker-compose*.yml text eol=lf
