# ============================================================
# BYOS AI + Security Suite — Local Development Environment
# ============================================================

# App
APP_NAME=BYOS AI + Security Suite
APP_VERSION=1.0.0
DEBUG=true
API_PREFIX=/api/v1

# Database - SQLite for local dev (no Docker needed)
DATABASE_URL=sqlite:///./local.db

# Redis - disabled for local dev
REDIS_URL=

# S3/MinIO - dummy values for local dev (required by boto3)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=dummy
S3_SECRET_ACCESS_KEY=dummy
S3_BUCKET_NAME=byos-ai
S3_REGION=us-east-1
S3_USE_SSL=false

# Security — Local dev keys
SECRET_KEY=local-dev-secret-key-change-in-production
ENCRYPTION_KEY=local-dev-encryption-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Auth hardening
MAX_FAILED_LOGIN_ATTEMPTS=10
ACCOUNT_LOCKOUT_MINUTES=30

# ── LLM — Local Ollama ────────────────────────────────────────────
OLLAMA_HOST=http://host.docker.internal:11434
LLM_MODEL_DEFAULT=qwen2.5:3b
LLM_FALLBACK=off

# External providers (optional for local dev)
OPENAI_API_KEY=
HUGGINGFACE_API_KEY=
GROQ_API_KEY=
SERP_API_KEY=

# Cost intelligence
COST_CURRENCY=USD
COST_PRECISION=6

# Feature flags
EDGE_ROUTING_ENABLED=false
AUTO_REMEDIATION_ENABLED=false
