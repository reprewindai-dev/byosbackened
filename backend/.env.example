# ============================================================
# BYOS AI + Security Suite â€” Environment Variables
# Copy to .env and fill in your values.
# Generate secrets: openssl rand -hex 32
# ============================================================

# App
APP_NAME=BYOS AI + Security Suite
APP_VERSION=1.0.0
DEBUG=false
API_PREFIX=/api/v1

# Database (production: set strong POSTGRES_PASSWORD)
DATABASE_URL=postgresql://byos:CHANGE_ME@postgres:5432/byos_ai
POSTGRES_USER=byos
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=byos_ai

# Redis (production: set REDIS_PASSWORD)
REDIS_URL=redis://:CHANGE_ME@redis:6379/0
REDIS_PASSWORD=CHANGE_ME

# S3/MinIO object storage
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=CHANGE_ME
S3_BUCKET_NAME=byos-ai
S3_REGION=us-east-1
S3_USE_SSL=false
S3_BACKUP_BUCKET=veklom-db-backups

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Security â€” REQUIRED in production
SECRET_KEY=GENERATE_WITH_openssl_rand_hex_32
ENCRYPTION_KEY=GENERATE_WITH_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://veklom.com/auth/github/callback

# Auth hardening
MAX_FAILED_LOGIN_ATTEMPTS=10
ACCOUNT_LOCKOUT_MINUTES=30

# â”€â”€ LLM â€” Local Ollama (required) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Ollama must be running on the host machine.
# Windows + Docker Desktop: host.docker.internal resolves to the Windows host.
# Install Ollama: https://ollama.com/download
# Recommended models by hardware:
#   i5/i7 + 16GB RAM (CPU-only):  qwen2.5:3b    (~10-15 tok/s, best quality/speed)
#   Any GPU 4GB+:                 llama3.2:3b   (fast, capable)
#   GPU 8GB+:                     llama3.1:8b   (high quality)
# Pull model: ollama pull qwen2.5:3b
#
# Inside Docker containers:
LLM_BASE_URL=http://host.docker.internal:11434
# For direct local run (no Docker):
# LLM_BASE_URL=http://127.0.0.1:11434

LLM_MODEL_DEFAULT=qwen2.5:3b
LLM_FALLBACK=groq
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=2048

# â”€â”€ Groq Fallback (self-healing circuit breaker) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# When Ollama fails 3+ times, circuit opens and routes automatically to Groq.
# Circuit resets after 60s cooldown when Ollama recovers.
# Free key: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
# Circuit breaker tuning (optional)
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_COOLDOWN_SECONDS=60

# â”€â”€ Conversation Memory â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Redis-backed per-tenant context. Pass conversation_id in /v1/exec requests.
MEMORY_TTL_SECONDS=86400
MEMORY_MAX_MESSAGES=20

# â”€â”€ External AI Providers (Optional) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Local Ollama inference works without any API keys. Set these only if you want
# to use external providers via the routing system.

# OpenAI (GPT-4, Whisper) â€” https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_CHAT=gpt-4o-mini
OPENAI_MODEL_WHISPER=whisper-1

# OpenAI-compatible modelfarm/proxy overrides.
# Use these for local/Replit/Coolify router experiments only when the target
# exposes /models and /chat/completions. Do not set these to localhost in
# production unless the modelfarm service runs inside the same container.
AI_INTEGRATIONS_OPENAI_BASE_URL=
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_GEMINI_BASE_URL=
AI_INTEGRATIONS_GEMINI_API_KEY=
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL_CHAT=gemini-2.5-pro

# HuggingFace (free tier available) â€” https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL_CHAT=mistralai/Mistral-7B-Instruct-v0.1
HUGGINGFACE_MODEL_EMBED=sentence-transformers/all-MiniLM-L6-v2

# SERP API (web search, optional) â€” https://serpapi.com
SERPAPI_KEY=
RESEND_API_KEY=

# â”€â”€ Stripe Billing â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Webhook secret from: https://dashboard.stripe.com/webhooks
# Endpoint URL: https://yourdomain.com/api/v1/subscriptions/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
LICENSE_ENFORCEMENT_ENABLED=false
LICENSE_VERIFY_URL=https://license.veklom.com/verify
LICENSE_VERIFY_BACKUP_URL=https://license2.veklom.com/verify
LICENSE_ISSUE_URL=https://license.veklom.com/issue
LICENSE_ISSUE_BACKUP_URL=https://license2.veklom.com/issue
LICENSE_KEY=
LICENSE_ADMIN_TOKEN=
LICENSE_CACHE_GRACE_HOURS=48
LICENSE_GRACE_HOURS=72
LICENSE_REVALIDATION_SECONDS=900
LICENSE_CACHE_PATH=
BUYER_DOWNLOAD_BASE_URL=https://veklom.com/downloads
BUYER_DOWNLOAD_VERSION=1.0.0

# SMTP / trial onboarding email
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
MAIL_FROM=hello@veklom.com
MAIL_REPLY_TO=support@veklom.com
RESEND_WEBHOOK_SECRET=

# â”€â”€ Worker (Celery) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

CELERY_BROKER_URL=redis://:CHANGE_ME@redis:6379/0
CELERY_RESULT_BACKEND=redis://:CHANGE_ME@redis:6379/0

# â”€â”€ CORS â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

# Production: set to your frontend domain(s)
CORS_ORIGINS=["https://yourdomain.com","https://app.yourdomain.com"]
CORS_ALLOW_CREDENTIALS=true

# â”€â”€ Content Safety â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

CONTENT_FILTERING_ENABLED=true

# Set true for adult content platforms â€” forces age verification before access
AGE_VERIFICATION_REQUIRED=false

# â”€â”€ Observability â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

SENTRY_DSN=
LOG_FORMAT=json
METRICS_ENABLED=true
PROMETHEUS_PORT=9090

# Grafana dashboard (internal)
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME
