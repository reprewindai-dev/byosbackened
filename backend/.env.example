# ============================================================
# BYOS AI + Security Suite — Environment Variables
# Copy to .env and fill in your values.
# Generate secrets: openssl rand -hex 32
# ============================================================

# App
APP_NAME=BYOS AI + Security Suite
APP_VERSION=1.0.0
DEBUG=false
API_PREFIX=/api/v1

# Database (production: set strong POSTGRES_PASSWORD)
DATABASE_URL=postgresql://byos:CHANGE_ME@postgres:5432/byos_ai
POSTGRES_USER=byos
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=byos_ai

# Redis (production: set REDIS_PASSWORD)
REDIS_URL=redis://:CHANGE_ME@redis:6379/0
REDIS_PASSWORD=CHANGE_ME

# S3/MinIO object storage
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=CHANGE_ME
S3_BUCKET_NAME=byos-ai
S3_REGION=us-east-1
S3_USE_SSL=false

# Security — REQUIRED in production
SECRET_KEY=GENERATE_WITH_openssl_rand_hex_32
ENCRYPTION_KEY=GENERATE_WITH_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Auth hardening
MAX_FAILED_LOGIN_ATTEMPTS=10
ACCOUNT_LOCKOUT_MINUTES=30

# ── LLM — Local Ollama (required) ────────────────────────────────────────────
# Ollama must be running on the host machine.
# Windows + Docker Desktop: host.docker.internal resolves to the Windows host.
# Install Ollama: https://ollama.com/download
# Pull model:    ollama pull llama3.2:1b
#
# Inside Docker containers:
LLM_BASE_URL=http://host.docker.internal:11434
# For direct local run (no Docker):
# LLM_BASE_URL=http://127.0.0.1:11434

LLM_MODEL_DEFAULT=llama3.2:1b
LLM_FALLBACK=off
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=2048

# SERP API (web search, optional)
SERPAPI_KEY=

# ── Stripe Billing ────────────────────────────────────────────────────────────

# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Webhook secret from: https://dashboard.stripe.com/webhooks
# Endpoint URL: https://yourdomain.com/api/v1/subscriptions/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Worker (Celery) ───────────────────────────────────────────────────────────

CELERY_BROKER_URL=redis://:CHANGE_ME@redis:6379/0
CELERY_RESULT_BACKEND=redis://:CHANGE_ME@redis:6379/0

# ── CORS ──────────────────────────────────────────────────────────────────────

# Production: set to your frontend domain(s)
CORS_ORIGINS=["https://yourdomain.com","https://app.yourdomain.com"]
CORS_ALLOW_CREDENTIALS=true

# ── Content Safety ────────────────────────────────────────────────────────────

CONTENT_FILTERING_ENABLED=true

# Set true for adult content platforms — forces age verification before access
AGE_VERIFICATION_REQUIRED=false

# ── Observability ─────────────────────────────────────────────────────────────

SENTRY_DSN=
LOG_FORMAT=json
METRICS_ENABLED=true
PROMETHEUS_PORT=9090

# Grafana dashboard (internal)
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME
