# =============================================================================
# BYOS Backend â€” Production Environment Template
# =============================================================================
# Copy to .env.production and fill in real values, OR set these directly in
# Render / Fly / DigitalOcean / your deploy platform's dashboard.
#
# Things marked REQUIRED must be set or the app refuses to start in production.
# =============================================================================

# â”€â”€ App â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
APP_NAME=BYOS AI Backend
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=info
LOG_FORMAT=json
API_PREFIX=/api/v1

# â”€â”€ Process / concurrency â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Number of gunicorn workers. Default is (2 * CPU cores).
# For a 2-core Render Standard: 4 workers is good.
WEB_CONCURRENCY=4

# â”€â”€ Database â€” REQUIRED â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Render / DO / Fly will inject this for you when DB is provisioned.
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:pass@host:5432/byos_ai

# â”€â”€ Redis â€” REQUIRED â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Without this, rate limiter falls back to in-process (won't share across workers),
# kill switch and L2 response cache are disabled.
REDIS_URL=redis://default:password@host:6379/0
CELERY_BROKER_URL=redis://default:password@host:6379/0
CELERY_RESULT_BACKEND=redis://default:password@host:6379/0

# â”€â”€ Secrets â€” REQUIRED â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Generate fresh: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_openssl_rand_hex_32
ENCRYPTION_KEY=CHANGE_ME_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://veklom.com/auth/github/callback

# â”€â”€ CORS â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Replace with your real frontend origin(s). Never use "*" in production with credentials.
# Example dual-domain setup:
# - veklom.com for public trust page
# - veklom.dev + app.veklom.dev for operating marketplace UI
CORS_ORIGINS=["https://veklom.com","https://www.veklom.com","https://veklom.dev","https://app.veklom.dev"]
CORS_ALLOW_CREDENTIALS=true

# â”€â”€ Object storage (S3 / R2 / MinIO) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
S3_ENDPOINT_URL=https://s3.amazonaws.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=byos-ai
S3_REGION=us-east-1
S3_USE_SSL=true
S3_BACKUP_BUCKET=veklom-db-backups

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# â”€â”€ AI providers â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL_CHAT=mistralai/Mistral-7B-Instruct-v0.1
HUGGINGFACE_MODEL_EMBED=sentence-transformers/all-MiniLM-L6-v2
SERPAPI_KEY=
OPENAI_API_KEY=
OPENAI_MODEL_CHAT=gpt-4o-mini
OPENAI_MODEL_WHISPER=whisper-1

# Self-hosted (optional)
LOCAL_WHISPER_URL=
LOCAL_LLM_URL=

# â”€â”€ Billing (Stripe) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
LICENSE_ENFORCEMENT_ENABLED=true
LICENSE_VERIFY_URL=https://license.veklom.com/verify
LICENSE_VERIFY_BACKUP_URL=https://license2.veklom.com/verify
LICENSE_ISSUE_URL=https://license.veklom.com/issue
LICENSE_ISSUE_BACKUP_URL=https://license2.veklom.com/issue
LICENSE_KEY=
LICENSE_ADMIN_TOKEN=
LICENSE_CACHE_GRACE_HOURS=48
LICENSE_GRACE_HOURS=72
LICENSE_REVALIDATION_SECONDS=900
LICENSE_CACHE_PATH=
BUYER_DOWNLOAD_BASE_URL=https://veklom.com/downloads
BUYER_DOWNLOAD_VERSION=1.0.0

# SMTP / trial onboarding email
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
MAIL_FROM=hello@veklom.com
MAIL_REPLY_TO=support@veklom.com
RESEND_WEBHOOK_SECRET=

# â”€â”€ Observability â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
SENTRY_DSN=
METRICS_ENABLED=true
PROMETHEUS_PORT=9090

# â”€â”€ Cost intelligence (kill switch defaults) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
GLOBAL_DAILY_COST_CAP_USD=500
WORKSPACE_DAILY_COST_CAP_USD=50
