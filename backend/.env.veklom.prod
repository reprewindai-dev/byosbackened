# Veklom Production Environment Configuration
# Deploy to: Coolify on Hetzner

# ============================================
# Core Application Settings
# ============================================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# ============================================
# Server Configuration
# ============================================
HOST=0.0.0.0
PORT=8000
WEB_CONCURRENCY=4

# ============================================
# Database (PostgreSQL on Hetzner)
# ============================================
# Will be provided by Coolify / Hetzner
DATABASE_URL=${DATABASE_URL}
POSTGRES_USER=${POSTGRES_USER}
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
POSTGRES_DB=${POSTGRES_DB}

# ============================================
# Redis (Caching & Session Store)
# ============================================
REDIS_URL=${REDIS_URL}
REDIS_PASSWORD=${REDIS_PASSWORD}

# Celery Configuration
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# ============================================
# JWT & Security
# ============================================
SECRET_KEY=${SECRET_KEY}
REFRESH_SECRET_KEY=${REFRESH_SECRET_KEY}
API_KEY_SALT=${API_KEY_SALT}
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ============================================
# Stripe (LIVE MODE)
# ============================================
STRIPE_SECRET_KEY=${STRIPE_SECRET_KEY}
STRIPE_WEBHOOK_SECRET=${STRIPE_WEBHOOK_SECRET}
STRIPE_PUBLISHABLE_KEY=${STRIPE_PUBLISHABLE_KEY}

# Stripe Price IDs (Production)
STRIPE_STARTER_PRICE_ID=${STRIPE_STARTER_PRICE_ID}
STRIPE_PRO_PRICE_ID=${STRIPE_PRO_PRICE_ID}
STRIPE_SOVEREIGN_PRICE_ID=${STRIPE_SOVEREIGN_PRICE_ID}
STRIPE_TOKEN_PACK_25_PRICE_ID=${STRIPE_TOKEN_PACK_25_PRICE_ID}
STRIPE_TOKEN_PACK_100_PRICE_ID=${STRIPE_TOKEN_PACK_100_PRICE_ID}
STRIPE_TOKEN_PACK_500_PRICE_ID=${STRIPE_TOKEN_PACK_500_PRICE_ID}
STRIPE_TOKEN_PACK_2000_PRICE_ID=${STRIPE_TOKEN_PACK_2000_PRICE_ID}

# ============================================
# LLM Configuration
# ============================================
LLM_BASE_URL=http://ollama:11434
LLM_MODEL_DEFAULT=qwen2.5:1.5b
LLM_FALLBACK=groq
GROQ_API_KEY=${GROQ_API_KEY}
GROQ_MODEL=llama-3.1-8b-instant

# Circuit Breaker Settings
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_COOLDOWN_SECONDS=60
MEMORY_TTL_SECONDS=86400
MEMORY_MAX_MESSAGES=20

# ============================================
# Feature Flags (Veklom Marketplace)
# ============================================
ENABLE_TOKEN_WALLET=true
ENABLE_ENTITLEMENT_CHECK=true
ENABLE_TOKEN_DEDUCTION=true
ENABLE_SUBSCRIPTION_MANAGEMENT=true

# ============================================
# Object Storage (MinIO / S3)
# ============================================
S3_ENDPOINT_URL=${S3_ENDPOINT_URL}
S3_ACCESS_KEY_ID=${S3_ACCESS_KEY_ID}
S3_SECRET_ACCESS_KEY=${S3_SECRET_ACCESS_KEY}
S3_BUCKET_NAME=${S3_BUCKET_NAME}

# ============================================
# Monitoring & Observability
# ============================================
SENTRY_DSN=${SENTRY_DSN}
ENABLE_METRICS=true
METRICS_PORT=9090

# ============================================
# CORS (Marketplace Frontend)
# ============================================
CORS_ORIGINS=["https://veklom.dev","https://www.veklom.dev","https://app.veklom.dev","https://veklom.com","https://www.veklom.com"]

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_AUTH_REQUESTS_PER_MINUTE=10
