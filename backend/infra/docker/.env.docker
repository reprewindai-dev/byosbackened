# Docker Compose Service Control
# Set to "true" to enable service, "false" to disable

# Core Infrastructure (always started)
ENABLE_POSTGRES=true
ENABLE_REDIS=true
ENABLE_MINIO=true

# Application Services
ENABLE_API=true
ENABLE_WORKER=true
ENABLE_CADDY=true

# Optional AI Services
ENABLE_WHISPER=false
ENABLE_LLM=false
