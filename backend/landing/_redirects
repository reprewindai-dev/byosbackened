# Cloudflare Pages redirects
# https://developers.cloudflare.com/pages/configuration/redirects/

# Force apex (no www). Keeps SEO single-canonical, avoids duplicate-content.
https://www.veklom.com/*  https://veklom.com/:splat  301

# Truthful workspace routes. The workspace shell is generated from
# frontend/workspace so all app routes use the same maintainable React build.
/dashboard         /workspace-app.html      200
/dashboard/        /workspace-app.html      200
/overview          /workspace-app.html      200
/overview/         /workspace-app.html      200
/playground        /workspace-app.html      200
/playground/       /workspace-app.html      200
/monitoring        /workspace-app.html      200
/monitoring/       /workspace-app.html      200
/models            /workspace-app.html      200
/models/           /workspace-app.html      200
/billing           /workspace-app.html      200
/billing/          /workspace-app.html      200
/marketplace       /workspace-app.html      200
/marketplace/      /workspace-app.html      200
/marketplace/*     /workspace-app.html      200
/vendors           /vendor/index.html       200
/vendors/          /vendor/index.html       200

# Legacy / compiled-shell aliases land on truthful surfaces
/pipelines         /workspace-app.html      200
/pipelines/*       /workspace-app.html      200
/deployments       /workspace-app.html      200
/deployments/*     /workspace-app.html      200
/vault             /workspace-app.html      200
/vault/*           /workspace-app.html      200
/compliance        /workspace-app.html      200
/compliance/*      /workspace-app.html      200
/team              /workspace-app.html      200
/team/*            /workspace-app.html      200
/settings          /workspace-app.html      200
/settings/*        /workspace-app.html      200
/onboarding        /workspace-app.html      200
/onboarding/*      /workspace-app.html      200

# Common typos / alternate paths land on real sections
/contact   /#contact   302
/pricing   /#pricing   302
/proof     /#proof     302
/architecture  /#architecture  302
/security  /#problem   302
/status          /status/index.html  200
/status/         /status/index.html  200
