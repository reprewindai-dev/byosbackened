# Cloudflare Pages redirects
# https://developers.cloudflare.com/pages/configuration/redirects/

# Force apex (no www). Keeps SEO single-canonical, avoids duplicate-content.
https://www.veklom.com/*  https://veklom.com/:splat  301

# Truthful workspace routes. The workspace shell is generated from
# frontend/workspace so all app routes use the same maintainable React build.
/dashboard         /workspace-app#/overview      302
/dashboard/        /workspace-app#/overview      302
/overview          /workspace-app#/overview      302
/overview/         /workspace-app#/overview      302
/playground        /workspace-app#/playground      302
/playground/       /workspace-app#/playground      302
/monitoring        /workspace-app#/monitoring      302
/monitoring/       /workspace-app#/monitoring      302
/models            /workspace-app#/models      302
/models/           /workspace-app#/models      302
/billing           /workspace-app#/billing      302
/billing/          /workspace-app#/billing      302
/marketplace       /workspace-app#/marketplace      302
/marketplace/      /workspace-app#/marketplace      302
/marketplace/*     /workspace-app#/marketplace/:splat      302
/vendors           /vendor/index.html       200
/vendors/          /vendor/index.html       200

# Legacy / compiled-shell aliases land on truthful surfaces
/pipelines         /workspace-app#/pipelines      302
/pipelines/*       /workspace-app#/pipelines      302
/deployments       /workspace-app#/deployments      302
/deployments/*     /workspace-app#/deployments      302
/vault             /workspace-app#/vault      302
/vault/*           /workspace-app#/vault      302
/compliance        /workspace-app#/compliance      302
/compliance/*      /workspace-app#/compliance      302
/team              /workspace-app#/team      302
/team/*            /workspace-app#/team      302
/accept-invite     /accept-invite.html      200
/accept-invite/    /accept-invite.html      200
/settings          /workspace-app#/settings      302
/settings/*        /workspace-app#/settings      302
/onboarding        /workspace-app#/overview      302
/onboarding/*      /workspace-app#/overview      302

# Common typos / alternate paths land on real sections
/contact   /#contact   302
/pricing   /#pricing   302
/proof     /#proof     302
/architecture  /#architecture  302
/security  /#problem   302
/status          /status/index.html  200
/status/         /status/index.html  200
/status.html     /status/index.html  301

# Legal canonical paths. Cloudflare Pages serves the .html file for the
# extensionless URL; only legacy aliases redirect to the canonical path.
/legal/terms.html     /legal/terms     301
/legal/privacy.html   /legal/privacy   301
/legal/sla.html       /legal/sla       301
/legal/license.html   /legal/license   301
/legal/vendor-agreement.html  /legal/vendor-agreement  301
/legal/vendor.html    /legal/vendor-agreement  301
/vendor-agreement     /legal/vendor-agreement  301
/legal/refunds.html   /legal/refunds   301
/legal/acceptable-use.html  /legal/acceptable-use  301

# Old workers.dev preview URL -> canonical
https://veklom.pages.dev/*  https://veklom.com/:splat  301
