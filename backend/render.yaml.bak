services:
  # PostgreSQL Database
  - type: pspg
    name: byos-ai-db
    databaseName: byos_ai
    user: byos_user
    plan: starter  # Change to standard-0, standard-1, etc. for production

  # Redis for Celery broker and result backend
  - type: redis
    name: byos-ai-redis
    plan: starter  # Change to standard-0, standard-1, etc. for production
    maxmemoryPolicy: allkeys-lru

  # API Web Service
  - type: web
    name: byos-ai-api
    runtime: docker
    dockerfilePath: ./infra/docker/Dockerfile.api
    dockerContext: .
    plan: starter  # Change to standard-0, standard-1, etc. for production
    healthCheckPath: /health
    envVars:
      # App Configuration
      - key: APP_NAME
        value: BYOS AI Backend
      - key: APP_VERSION
        value: 0.1.0
      - key: DEBUG
        value: false
      - key: API_PREFIX
        value: /api/v1

      # Database - Uses Render's internal database URL
      - key: DATABASE_URL
        fromDatabase:
          name: byos-ai-db
          property: connectionString

      # Redis - Uses Render's internal Redis URL
      - key: REDIS_URL
        fromService:
          type: redis
          name: byos-ai-redis
          property: connectionString

      # Celery Configuration
      - key: CELERY_BROKER_URL
        fromService:
          type: redis
          name: byos-ai-redis
          property: connectionString
      - key: CELERY_RESULT_BACKEND
        fromService:
          type: redis
          name: byos-ai-redis
          property: connectionString

      # S3/MinIO Configuration
      # For production, use AWS S3 or compatible service
      - key: S3_ENDPOINT_URL
        sync: false  # Set manually in Render dashboard
      - key: S3_ACCESS_KEY_ID
        sync: false  # Set manually in Render dashboard
      - key: S3_SECRET_ACCESS_KEY
        sync: false  # Set manually in Render dashboard
      - key: S3_BUCKET_NAME
        value: byos-ai
      - key: S3_REGION
        value: us-east-1
      - key: S3_USE_SSL
        value: true

      # Security - IMPORTANT: Generate and set these in Render dashboard
      - key: SECRET_KEY
        sync: false  # Generate with: openssl rand -hex 32
      - key: ENCRYPTION_KEY
        sync: false  # Optional, defaults to SECRET_KEY if not set
      - key: ALGORITHM
        value: HS256
      - key: ACCESS_TOKEN_EXPIRE_MINUTES
        value: 30

      # AI Providers - Set these in Render dashboard
      - key: HUGGINGFACE_API_KEY
        sync: false
      - key: HUGGINGFACE_MODEL_CHAT
        value: mistralai/Mistral-7B-Instruct-v0.1
      - key: HUGGINGFACE_MODEL_EMBED
        value: sentence-transformers/all-MiniLM-L6-v2

      - key: SERPAPI_KEY
        sync: false

      # OpenAI (Optional)
      - key: OPENAI_API_KEY
        sync: false
      - key: OPENAI_MODEL_CHAT
        value: gpt-4o-mini
      - key: OPENAI_MODEL_WHISPER
        value: whisper-1

      # Local AI (Optional - for self-hosted models)
      - key: LOCAL_WHISPER_URL
        sync: false
      - key: LOCAL_LLM_URL
        sync: false

      # CORS
      - key: CORS_ORIGINS
        value: '["*"]'  # Update with your frontend domain(s) in production
      - key: CORS_ALLOW_CREDENTIALS
        value: true

      # Observability
      - key: SENTRY_DSN
        sync: false  # Optional
      - key: LOG_FORMAT
        value: json
      - key: METRICS_ENABLED
        value: true
      - key: PROMETHEUS_PORT
        value: 9090

  # Celery Worker Background Service
  - type: worker
    name: byos-ai-worker
    runtime: docker
    dockerfilePath: ./infra/docker/Dockerfile.worker
    dockerContext: .
    plan: starter  # Change to standard-0, standard-1, etc. for production
    envVars:
      # App Configuration
      - key: APP_NAME
        value: BYOS AI Backend Worker
      - key: APP_VERSION
        value: 0.1.0
      - key: DEBUG
        value: false

      # Database
      - key: DATABASE_URL
        fromDatabase:
          name: byos-ai-db
          property: connectionString

      # Redis
      - key: REDIS_URL
        fromService:
          type: redis
          name: byos-ai-redis
          property: connectionString

      # Celery Configuration
      - key: CELERY_BROKER_URL
        fromService:
          type: redis
          name: byos-ai-redis
          property: connectionString
      - key: CELERY_RESULT_BACKEND
        fromService:
          type: redis
          name: byos-ai-redis
          property: connectionString

      # S3/MinIO Configuration
      - key: S3_ENDPOINT_URL
        sync: false
      - key: S3_ACCESS_KEY_ID
        sync: false
      - key: S3_SECRET_ACCESS_KEY
        sync: false
      - key: S3_BUCKET_NAME
        value: byos-ai
      - key: S3_REGION
        value: us-east-1
      - key: S3_USE_SSL
        value: true

      # Security
      - key: SECRET_KEY
        sync: false
      - key: ENCRYPTION_KEY
        sync: false
      - key: ALGORITHM
        value: HS256

      # AI Providers
      - key: HUGGINGFACE_API_KEY
        sync: false
      - key: HUGGINGFACE_MODEL_CHAT
        value: mistralai/Mistral-7B-Instruct-v0.1
      - key: HUGGINGFACE_MODEL_EMBED
        value: sentence-transformers/all-MiniLM-L6-v2

      - key: SERPAPI_KEY
        sync: false

      - key: OPENAI_API_KEY
        sync: false
      - key: OPENAI_MODEL_CHAT
        value: gpt-4o-mini
      - key: OPENAI_MODEL_WHISPER
        value: whisper-1

      - key: LOCAL_WHISPER_URL
        sync: false
      - key: LOCAL_LLM_URL
        sync: false

      # Observability
      - key: LOG_FORMAT
        value: json
      - key: METRICS_ENABLED
        value: true
